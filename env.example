# LLM API Configuration
# Copy this file to .env for local development only.

# --- Production: use Server (proxy). Do NOT set REACT_APP_LLM_API_KEY for production builds ---
# REACT_APP_* is baked into the frontend bundle and is visible to anyone who visits the site.
# On the server, set OPENAI_API_KEY and run: npm run llm:server (see DEPLOY.md).

# --- Local development: optional. Default is Server (proxy); set below for direct/BYOK ---
# REACT_APP_LLM_API_KEY=your_openai_api_key_here
# REACT_APP_LLM_PROVIDER=openai
# REACT_APP_LLM_MODEL=gpt-4

# Example for other providers (for local dev or when using in-app API Configuration):
# For Anthropic Claude:
# REACT_APP_LLM_API_KEY=your_anthropic_api_key_here
# REACT_APP_LLM_PROVIDER=anthropic
# REACT_APP_LLM_MODEL=claude-3-opus-20240229
# REACT_APP_LLM_ANTHROPIC_VERSION=2023-06-01

# For local Ollama (no API key needed):
# REACT_APP_LLM_PROVIDER=ollama
# REACT_APP_LLM_OLLAMA_ENDPOINT=http://localhost:11434/api/chat
# REACT_APP_LLM_OLLAMA_MODEL=llama2

# Note: After changing .env, restart the development server.
