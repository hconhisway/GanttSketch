# LLM API Configuration
# Copy this file to .env and fill in your API key

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
REACT_APP_LLM_API_KEY=your_openai_api_key_here

# Example for other providers:
# For Anthropic Claude:
# REACT_APP_LLM_API_KEY=your_anthropic_api_key_here

# For local Ollama (no API key needed):
# REACT_APP_LLM_API_KEY=

# Note: After setting up your .env file, restart your development server

