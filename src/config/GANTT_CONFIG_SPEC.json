{
  "name": "GanttConfigSpec",
  "version": 1,
  "description": "Formal configuration spec for the Gantt chart. Includes rule-driven fields and safe JSON AST rules.",
  "ruleDsl": {
    "ruleShapes": [
      { "type": "expr", "shape": { "type": "expr", "expr": { "op": "..." } } },
      { "type": "transform", "shape": { "type": "transform", "name": "...", "params": {} } },
      { "type": "predicate", "shape": { "type": "predicate", "when": { "op": "..." } } }
    ],
    "exprOps": [
      "get",
      "var",
      "coalesce",
      "concat",
      "lower",
      "upper",
      "trim",
      "==",
      "!=",
      ">",
      ">=",
      "<",
      "<=",
      "and",
      "or",
      "not",
      "case",
      "if",
      "add",
      "sub",
      "mul",
      "div",
      "clamp",
      "len",
      "regexTest",
      "regexCapture",
      "hash",
      "paletteHash",
      "formatTimeUs",
      "formatTimeUsFull",
      "formatDurationUs"
    ],
    "transformNames": [
      "forkTree",
      "sortBy",
      "groupBy",
      "customList",
      "groupList",
      "filter",
      "pipeline",
      "pidAsc",
      "pidDesc",
      "autoPack",
      "byLevel"
    ],
    "context": {
      "event": "Current event object (for color/tooltip)",
      "hierarchy1": "Hierarchy1 id (key)",
      "hierarchy2": "Hierarchy2 id (key)",
      "hierarchy3": "Hierarchy3 id (key, when present)",
      "level": "Lane level number",
      "trackKey": "Current track key",
      "stats": "Per-hierarchy1 stats: count, totalDurUs, avgDurUs, maxDurUs, minStart, maxEnd",
      "isExpanded": "Boolean for hierarchy1 expanded state",
      "isMainThread": "Boolean for hierarchy2 label",
      "hierarchy3Field": "Display name for hierarchy3 field (dynamic hierarchy)"
    }
  },
  "sections": [
    {
      "id": "layout",
      "description": "Chart layout and sizing parameters.",
      "entries": [
        {
          "id": "layout.margin",
          "path": "layout.margin",
          "kind": "value",
          "schema": { "type": "object", "fields": ["top", "right", "bottom", "left"] },
          "default": { "top": 24, "right": 24, "bottom": 24, "left": 16 }
        },
        {
          "id": "layout.headerHeight",
          "path": "layout.headerHeight",
          "kind": "value",
          "schema": { "type": "number", "min": 12, "max": 80 },
          "default": 24
        },
        {
          "id": "layout.laneHeight",
          "path": "layout.laneHeight",
          "kind": "value",
          "schema": { "type": "number", "min": 8, "max": 60 },
          "default": 18
        },
        {
          "id": "layout.lanePadding",
          "path": "layout.lanePadding",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 20 },
          "default": 3
        },
        {
          "id": "layout.expandedPadding",
          "path": "layout.expandedPadding",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 30 },
          "default": 8
        },
        {
          "id": "layout.hierarchy2Gap",
          "path": "layout.hierarchy2Gap",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 30 },
          "default": 6
        },
        {
          "id": "layout.nestedRowHeight",
          "path": "layout.nestedRowHeight",
          "kind": "value",
          "schema": { "type": "number", "min": 20, "max": 120 },
          "default": 36,
          "description": "Height of the nested hierarchy display row when hierarchyDisplayMode is nested."
        },
        {
          "id": "layout.nestedLevelInset",
          "path": "layout.nestedLevelInset",
          "kind": "value",
          "schema": { "type": "number", "min": 1, "max": 12 },
          "default": 3,
          "description": "Vertical inset per hierarchy depth for nested hierarchy display."
        },
        {
          "id": "layout.yAxis",
          "path": "layout.yAxis",
          "kind": "value",
          "schema": {
            "type": "object",
            "fields": [
              "autoWidth",
              "baseWidth",
              "minWidth",
              "maxWidth",
              "hierarchy1Indent",
              "labelPadding",
              "hierarchy1Font",
              "hierarchy2Font"
            ]
          }
        },
        {
          "id": "layout.label.minBarLabelPx",
          "path": "layout.label.minBarLabelPx",
          "kind": "value",
          "schema": { "type": "number", "min": 20, "max": 240 },
          "default": 90
        }
      ]
    },
    {
      "id": "xAxis",
      "description": "Time axis configuration.",
      "entries": [
        {
          "id": "xAxis.timeFormat",
          "path": "xAxis.timeFormat",
          "kind": "value",
          "schema": { "type": "string", "enum": ["short", "full"] },
          "default": "short",
          "description": "Time label format for x-axis ticks."
        },
        {
          "id": "xAxis.timeScaleMode",
          "path": "xAxis.timeScaleMode",
          "kind": "value",
          "schema": {
            "type": "string",
            "enum": ["physical", "logarithmic", "fisheye", "logical"]
          },
          "default": "physical",
          "description": "Selects the x-axis time transform used for the main chart."
        },
        {
          "id": "xAxis.logarithmic.base",
          "path": "xAxis.logarithmic.base",
          "kind": "value",
          "schema": { "type": "number", "min": 1.01, "max": 1000 },
          "default": 2.718281828459045,
          "description": "Curvature parameter for logarithmic time compression. Larger values emphasize early time ranges more strongly."
        },
        {
          "id": "xAxis.fisheye.distortion",
          "path": "xAxis.fisheye.distortion",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 10 },
          "default": 3,
          "description": "Distortion strength for fisheye focus+context scaling."
        },
        {
          "id": "xAxis.fisheye.focusTime",
          "path": "xAxis.fisheye.focusTime",
          "kind": "value",
          "schema": { "type": "number" },
          "description": "Optional fixed fisheye focus time. When omitted, the focus follows the pointer."
        }
      ]
    },
    {
      "id": "yAxis",
      "description": "Y-axis configuration, such as hierarchies.",
      "entries": [
        {
          "id": "yAxis.hierarchy1OrderRule",
          "path": "yAxis.hierarchy1OrderRule",
          "kind": "rule",
          "schema": {
            "type": "transform",
            "names": [
              "forkTree",
              "sortBy",
              "groupBy",
              "customList",
              "groupList",
              "filter",
              "pipeline",
              "pidAsc",
              "pidDesc"
            ]
          }
        },
        {
          "id": "yAxis.hierarchy2LaneRule",
          "path": "yAxis.hierarchy2LaneRule",
          "kind": "rule",
          "schema": {
            "type": "transform",
            "names": ["autoPack", "byField", "byLevel"]
          }
        },
        {
          "id": "yAxis.hierarchyDisplayMode",
          "path": "yAxis.hierarchyDisplayMode",
          "kind": "value",
          "schema": { "type": "string", "enum": ["rows", "nested"] },
          "default": "rows",
          "description": "How expanded hierarchies render: separate rows or vertically nested rectangles."
        },
        {
          "id": "yAxis.hierarchy1AggregationRule",
          "path": "yAxis.hierarchy1AggregationRule",
          "kind": "value",
          "schema": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["mergeGap"] },
              "mergeGapRatio": { "type": "number", "min": 0, "max": 1 },
              "minGapUs": { "type": "number", "min": 0 }
            }
          },
          "default": { "type": "mergeGap", "mergeGapRatio": 0.002 },
          "description": "Aggregation rule for hierarchy level 1 parent segments."
        },
        {
          "id": "yAxis.hierarchy2AggregationRule",
          "path": "yAxis.hierarchy2AggregationRule",
          "kind": "value",
          "schema": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["mergeGap"] },
              "mergeGapRatio": { "type": "number", "min": 0, "max": 1 },
              "minGapUs": { "type": "number", "min": 0 }
            }
          },
          "default": { "type": "mergeGap", "mergeGapRatio": 0.002 },
          "description": "Aggregation rule for hierarchy level 2 parent segments."
        },
        {
          "id": "yAxis.hierarchy1LabelRule",
          "path": "yAxis.hierarchy1LabelRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "yAxis.hierarchy2LabelRule",
          "path": "yAxis.hierarchy2LabelRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        }
      ]
    },
    {
      "id": "color",
      "description": "Color palette and rule-based mapping.",
      "entries": [
        {
          "id": "color.palette",
          "path": "color.palette",
          "kind": "value",
          "schema": { "type": "array", "items": "hexColor" }
        },
        {
          "id": "color.keyRule",
          "path": "color.keyRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "color.colorRule",
          "path": "color.colorRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "color.fixedColor",
          "path": "color.fixedColor",
          "kind": "value",
          "schema": { "type": "string", "format": "hexColor" },
          "description": "If set, overrides rule output with a single color."
        }
      ]
    },
    {
      "id": "tooltip",
      "description": "Tooltip content with rule-based fields.",
      "entries": [
        {
          "id": "tooltip.enabled",
          "path": "tooltip.enabled",
          "kind": "value",
          "schema": { "type": "boolean" },
          "default": true
        },
        {
          "id": "tooltip.hierarchy1.fields",
          "path": "tooltip.hierarchy1.fields",
          "kind": "value",
          "schema": {
            "type": "array",
            "items": {
              "label": "string|expr",
              "value": "expr",
              "path": "string",
              "when": "predicate",
              "showEmpty": "boolean"
            }
          }
        },
        {
          "id": "tooltip.event.fields",
          "path": "tooltip.event.fields",
          "kind": "value",
          "schema": {
            "type": "array",
            "items": {
              "label": "string|expr",
              "value": "expr",
              "path": "string",
              "when": "predicate",
              "showEmpty": "boolean"
            }
          }
        },
        {
          "id": "tooltip.event.args",
          "path": "tooltip.event.args",
          "kind": "value",
          "schema": {
            "enabled": "boolean",
            "max": "number",
            "sort": "alpha|none",
            "label": "string",
            "filter": "predicate",
            "value": "expr"
          }
        }
      ]
    },
    {
      "id": "dependencies",
      "title": "Dependencies",
      "description": "Dependency edge visualization between events.",
      "entries": [
        {
          "id": "dependencies.connector",
          "path": "dependencies.connector",
          "kind": "value",
          "schema": { "type": "string", "enum": ["line", "arrow"] },
          "default": "arrow",
          "description": "Connector type: plain line or arrow with arrowhead."
        },
        {
          "id": "dependencies.amount",
          "path": "dependencies.amount",
          "kind": "value",
          "schema": { "type": "string", "enum": ["all", "paths", "1hop"] },
          "default": "1hop",
          "description": "How many edges to show: all edges, transitive paths from selection, or 1-hop neighbors."
        },
        {
          "id": "dependencies.persistence",
          "path": "dependencies.persistence",
          "kind": "value",
          "schema": { "type": "string", "enum": ["always", "toggle", "onClick"] },
          "default": "onClick",
          "description": "When to show edges: always visible, toggle button, or on event click."
        },
        {
          "id": "dependencies.drawingStyle",
          "path": "dependencies.drawingStyle",
          "kind": "value",
          "schema": {
            "type": "string",
            "enum": ["straight", "orthogonal", "spline", "bundled"]
          },
          "default": "spline",
          "description": "Edge drawing style: straight lines, orthogonal right-angles, smooth splines, or bundled edges."
        },
        {
          "id": "dependencies.strokeColor",
          "path": "dependencies.strokeColor",
          "kind": "value",
          "schema": { "type": "string" },
          "default": "rgba(59,130,246,0.45)",
          "description": "Stroke color used for dependency edges."
        },
        {
          "id": "dependencies.strokeWidth",
          "path": "dependencies.strokeWidth",
          "kind": "value",
          "schema": { "type": "number", "min": 0.5, "max": 12 },
          "default": 1.5,
          "description": "Stroke width in pixels used for dependency edges."
        },
        {
          "id": "dependencies.arrowSize",
          "path": "dependencies.arrowSize",
          "kind": "value",
          "schema": { "type": "number", "min": 2, "max": 24 },
          "default": 6,
          "description": "Arrowhead size in pixels when connector is set to arrow."
        },
        {
          "id": "dependencies.maxEdges",
          "path": "dependencies.maxEdges",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 5000 },
          "default": 200,
          "description": "Maximum number of dependency edges to render."
        }
      ]
    },
    {
      "id": "performance",
      "description": "Performance tuning and diagnostics.",
      "entries": [
        {
          "id": "performance.hierarchy1LOD.mergeUtilGap",
          "path": "performance.hierarchy1LOD.mergeUtilGap",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 1 },
          "default": 0.002,
          "description": "Hierarchy1 merge gap as fraction of time window for LOD."
        },
        {
          "id": "performance.hierarchy2LOD.pixelWindow",
          "path": "performance.hierarchy2LOD.pixelWindow",
          "kind": "value",
          "schema": { "type": "number", "min": 1, "max": 64 },
          "default": 1,
          "description": "Hierarchy2 LOD pixel window size."
        },
        {
          "id": "performance.webglEnabled",
          "path": "performance.webglEnabled",
          "kind": "value",
          "schema": { "type": "boolean" },
          "default": false,
          "description": "Enable WebGL rendering when available."
        },
        {
          "id": "performance.showOverlay",
          "path": "performance.showOverlay",
          "kind": "value",
          "schema": { "type": "boolean" },
          "default": false,
          "description": "Show performance overlay."
        }
      ]
    },
    {
      "id": "extensions",
      "description": "Reserved extension bag for future features.",
      "entries": [
        {
          "id": "extensions",
          "path": "extensions",
          "kind": "value",
          "schema": { "type": "object" }
        }
      ]
    },
    {
      "id": "auxCharts",
      "title": "Auxiliary Charts",
      "description": "Auxiliary overview chart (minimap) type and options.",
      "entries": [
        {
          "id": "extensions.auxCharts.enabled",
          "path": "extensions.auxCharts.enabled",
          "kind": "value",
          "schema": { "type": "boolean" },
          "default": true,
          "description": "Enable auxiliary overview chart in the top bar."
        },
        {
          "id": "extensions.auxCharts.overview.kind",
          "path": "extensions.auxCharts.overview.kind",
          "kind": "value",
          "schema": { "type": "string", "enum": ["utilizationArea", "utilizationCount", "stackedArea"] },
          "default": "utilizationArea",
          "description": "Overview chart type: utilizationArea (% per pixel), utilizationCount (active process count), or stackedArea (multiple series)."
        },
        {
          "id": "extensions.auxCharts.overview",
          "path": "extensions.auxCharts.overview",
          "kind": "value",
          "schema": { "type": "object", "fields": ["kind", "entityLevel", "bins", "count", "stacked"] },
          "description": "Full overview chart config (kind, entityLevel, bins, count, stacked)."
        }
      ]
    }
  ],
  "examples": [
    {
      "title": "Fork tree with tie-break",
      "patch": {
        "yAxis": {
          "hierarchy1OrderRule": {
            "type": "transform",
            "name": "forkTree",
            "params": {
              "includeUnspecified": true,
              "tieBreak": { "op": "sub", "args": [0, { "op": "get", "path": "stats.totalDurUs" }] }
            }
          }
        }
      }
    },
    {
      "title": "Tooltip simplified",
      "patch": {
        "tooltip": {
          "event": {
            "fields": [
              { "label": "Name", "value": { "op": "get", "path": "event.name" } },
              { "label": "Phase", "value": { "op": "get", "path": "event.args.phase" } },
              {
                "label": "Duration",
                "value": {
                  "op": "formatDurationUs",
                  "args": [{ "op": "var", "name": "durationUs" }]
                }
              }
            ],
            "args": { "enabled": false }
          }
        }
      }
    }
  ]
}
