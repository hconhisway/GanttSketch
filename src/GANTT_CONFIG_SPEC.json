{
  "name": "GanttConfigSpec",
  "version": 1,
  "description": "Formal configuration spec for the Gantt chart. Includes rule-driven fields and safe JSON AST rules.",
  "ruleDsl": {
    "ruleShapes": [
      { "type": "expr", "shape": { "type": "expr", "expr": { "op": "..." } } },
      { "type": "transform", "shape": { "type": "transform", "name": "...", "params": {} } },
      { "type": "predicate", "shape": { "type": "predicate", "when": { "op": "..." } } }
    ],
    "exprOps": [
      "get", "var", "coalesce", "concat", "lower", "upper", "trim",
      "==", "!=", ">", ">=", "<", "<=", "and", "or", "not", "case", "if",
      "add", "sub", "mul", "div", "clamp", "len",
      "regexTest", "regexCapture",
      "hash", "paletteHash",
      "formatTimeUs", "formatTimeUsFull", "formatDurationUs"
    ],
    "transformNames": [
      "forkTree",
      "sortBy",
      "groupBy",
      "customList",
      "groupList",
      "filter",
      "pipeline",
      "pidAsc",
      "pidDesc",
      "autoPack",
      "byLevel"
    ],
    "context": {
      "event": "Current event object (for color/tooltip)",
      "pid": "Process id string",
      "tid": "Thread id string",
      "level": "Lane level number",
      "trackKey": "Current track key",
      "stats": "Per-process stats: count, totalDurUs, avgDurUs, maxDurUs, minStart, maxEnd",
      "isExpanded": "Boolean for process expanded state",
      "isMainThread": "Boolean for thread label"
    }
  },
  "sections": [
    {
      "id": "layout",
      "description": "Chart layout and sizing parameters.",
      "entries": [
        {
          "id": "layout.margin",
          "path": "layout.margin",
          "kind": "value",
          "schema": { "type": "object", "fields": ["top", "right", "bottom", "left"] },
          "default": { "top": 24, "right": 24, "bottom": 24, "left": 16 }
        },
        {
          "id": "layout.headerHeight",
          "path": "layout.headerHeight",
          "kind": "value",
          "schema": { "type": "number", "min": 12, "max": 80 },
          "default": 24
        },
        {
          "id": "layout.laneHeight",
          "path": "layout.laneHeight",
          "kind": "value",
          "schema": { "type": "number", "min": 8, "max": 60 },
          "default": 18
        },
        {
          "id": "layout.lanePadding",
          "path": "layout.lanePadding",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 20 },
          "default": 3
        },
        {
          "id": "layout.expandedPadding",
          "path": "layout.expandedPadding",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 30 },
          "default": 8
        },
        {
          "id": "layout.threadGap",
          "path": "layout.threadGap",
          "kind": "value",
          "schema": { "type": "number", "min": 0, "max": 30 },
          "default": 6
        },
        {
          "id": "layout.yAxis",
          "path": "layout.yAxis",
          "kind": "value",
          "schema": {
            "type": "object",
            "fields": [
              "autoWidth", "baseWidth", "minWidth", "maxWidth",
              "processIndent", "labelPadding", "processFont", "threadFont"
            ]
          }
        },
        {
          "id": "layout.label.minBarLabelPx",
          "path": "layout.label.minBarLabelPx",
          "kind": "value",
          "schema": { "type": "number", "min": 20, "max": 240 },
          "default": 90
        }
      ]
    },
    {
      "id": "yAxis",
      "description": "Process ordering, thread lane policy, and labels.",
      "entries": [
        {
          "id": "yAxis.processOrderRule",
          "path": "yAxis.processOrderRule",
          "kind": "rule",
          "schema": {
            "type": "transform",
            "names": ["forkTree", "sortBy", "groupBy", "customList", "groupList", "filter", "pipeline", "pidAsc", "pidDesc"]
          }
        },
        {
          "id": "yAxis.threadLaneRule",
          "path": "yAxis.threadLaneRule",
          "kind": "rule",
          "schema": {
            "type": "transform",
            "names": ["autoPack", "byLevel"]
          }
        },
        {
          "id": "yAxis.processLabelRule",
          "path": "yAxis.processLabelRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "yAxis.threadLabelRule",
          "path": "yAxis.threadLabelRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        }
      ]
    },
    {
      "id": "color",
      "description": "Color palette and rule-based mapping.",
      "entries": [
        {
          "id": "color.palette",
          "path": "color.palette",
          "kind": "value",
          "schema": { "type": "array", "items": "hexColor" }
        },
        {
          "id": "color.keyRule",
          "path": "color.keyRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "color.colorRule",
          "path": "color.colorRule",
          "kind": "rule",
          "schema": { "type": "expr" }
        },
        {
          "id": "color.fixedColor",
          "path": "color.fixedColor",
          "kind": "value",
          "schema": { "type": "string", "format": "hexColor" },
          "description": "If set, overrides rule output with a single color."
        }
      ]
    },
    {
      "id": "tooltip",
      "description": "Tooltip content with rule-based fields.",
      "entries": [
        {
          "id": "tooltip.enabled",
          "path": "tooltip.enabled",
          "kind": "value",
          "schema": { "type": "boolean" },
          "default": true
        },
        {
          "id": "tooltip.process.fields",
          "path": "tooltip.process.fields",
          "kind": "value",
          "schema": {
            "type": "array",
            "items": {
              "label": "string|expr",
              "value": "expr",
              "path": "string",
              "when": "predicate",
              "showEmpty": "boolean"
            }
          }
        },
        {
          "id": "tooltip.event.fields",
          "path": "tooltip.event.fields",
          "kind": "value",
          "schema": {
            "type": "array",
            "items": {
              "label": "string|expr",
              "value": "expr",
              "path": "string",
              "when": "predicate",
              "showEmpty": "boolean"
            }
          }
        },
        {
          "id": "tooltip.event.args",
          "path": "tooltip.event.args",
          "kind": "value",
          "schema": {
            "enabled": "boolean",
            "max": "number",
            "sort": "alpha|none",
            "label": "string",
            "filter": "predicate",
            "value": "expr"
          }
        }
      ]
    },
    {
      "id": "extensions",
      "description": "Reserved extension bag for future features.",
      "entries": [
        {
          "id": "extensions",
          "path": "extensions",
          "kind": "value",
          "schema": { "type": "object" }
        }
      ]
    }
  ],
  "examples": [
    {
      "title": "Fork tree with tie-break",
      "patch": {
        "yAxis": {
          "processOrderRule": {
            "type": "transform",
            "name": "forkTree",
            "params": {
              "includeUnspecified": true,
              "tieBreak": { "op": "sub", "args": [0, { "op": "get", "path": "stats.totalDurUs" }] }
            }
          }
        }
      }
    },
    {
      "title": "Tooltip simplified",
      "patch": {
        "tooltip": {
          "event": {
            "fields": [
              { "label": "Name", "value": { "op": "get", "path": "event.name" } },
              { "label": "Phase", "value": { "op": "get", "path": "event.args.phase" } },
              { "label": "Duration", "value": { "op": "formatDurationUs", "args": [{ "op": "var", "name": "durationUs" }] } }
            ],
            "args": { "enabled": false }
          }
        }
      }
    }
  ]
}
